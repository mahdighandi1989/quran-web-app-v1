rules_version = '2';

// Firestore security rules for the Quran web app.
// Per-user Telegram config lives at telegramConfigs/{uid}. Each signed-in user can read and
// write ONLY their own document — no one can read another account's bot token / chat ids.
//
// Deploy: Firebase Console → Firestore Database → Rules → paste & Publish,
// or with the CLI:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user Telegram config (bot token, chat ids, devices, prefs, reminders, allChatIds).
    match /telegramConfigs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user app-state summary the web app mirrors here for the bot to read.
    match /appState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Per-user AI provider config + API keys (owner-only; keys never readable by others).
    match /aiConfigs/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Everything else is denied by default. (The bot server uses the Admin SDK, which
    // bypasses these rules, to resolve chat->user and answer commands.)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
