# Local environment files — contain real secrets/config, never commit them.
# (.env.example is kept tracked so contributors know which vars are required.)
.env
.env.local
.env.*.local
*.local
!.env.example

# Secrets & credentials — never commit these to the repository.
credentials.json
service-account*.json
*.key
*.pem
secrets.yml
secrets.yaml
htpasswd
*.p12
*.pfx

# Editor / IDE
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# OS files
.DS_Store
Thumbs.db
