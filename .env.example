# Firebase web config — copy this file to `.env` and fill in your project's values.
# These are read at BUILD time by Vite (only variables prefixed with VITE_ are exposed
# to the client). Find these values in the Firebase console:
#   Project settings → General → Your apps → SDK setup and configuration.
# `.env` is git-ignored; never commit real values. In production set these in your
# deploy platform's environment-variable settings instead.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id
