# Firebase web config — copy this file to `.env` and fill in your project's values.
# These are read at BUILD time by Vite (only variables prefixed with VITE_ are exposed
# to the client). Find these values in the Firebase console:
#   Project settings → General → Your apps → SDK setup and configuration.
# `.env` is git-ignored; never commit real values. In production set these in your
# deploy platform's environment-variable settings instead.
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=your-measurement-id

# Backend AI proxy URL (build-time). When set, the app routes AI chat through this proxy so
# provider API keys never reach the browser bundle / network tab. Point it at a host that serves
# `POST /api/ai/proxy` — the Telegram bot server (server/) exposes exactly that endpoint. Leave
# unset to fall back to direct "bring-your-own-key" calls from the browser. See server/README.md.
VITE_AI_PROXY_URL=

# Inspector Bridge (in-page debug/inspector tool). Leave false/unset in production — the
# whole bridge (incl. its WebSocket connection) only runs when this is exactly "true".
# Set to true ONLY in local development if you use the inspector.
VITE_ENABLE_INSPECTOR_BRIDGE=false

# ──────────────────────────────────────────────────────────────────────────────
# Telegram bot server (server/telegram-bot.mjs) — RUNTIME env, NOT build-time.
# These are NOT VITE_-prefixed and are never exposed to the browser. The bot is
# deployed as its own service (Render Web Service with rootDir `server/`, a VPS,
# Cloud Run, …); set these in that service's environment. They are listed here so
# the full set of env vars the project reads lives in one place. See server/README.md.
# ──────────────────────────────────────────────────────────────────────────────

# Bot token from @BotFather. REQUIRED — without it the bot can't reply.
TELEGRAM_BOT_TOKEN=

# Shared secret verified against Telegram's X-Telegram-Bot-Api-Secret-Token header.
# Strongly recommended. Generate one with e.g. `openssl rand -hex 16` and pass the
# same value to setWebhook (?secret_token=...).
TELEGRAM_WEBHOOK_SECRET=

# Firestore access for the Admin SDK. Provide ONE of the two:
#   1) FIREBASE_SERVICE_ACCOUNT — the service-account JSON as a single-line string
#      (Firebase Console → Project settings → Service accounts → Generate new private key).
#   2) GOOGLE_APPLICATION_CREDENTIALS — path to that service-account JSON file.
# If neither is set the bot still boots, but data/AI commands degrade gracefully.
FIREBASE_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS=

# Port the bot's HTTP server listens on. Defaults to 3001 if unset. On managed
# platforms (Render, Cloud Run, …) the platform injects this automatically.
PORT=3001

# Public URL the server self-pings to stay awake on free tiers. On Render this is
# auto-injected as RENDER_EXTERNAL_URL (leave it unset — the platform provides it);
# set SELF_URL only when hosting elsewhere. Leave both blank for local development.
RENDER_EXTERNAL_URL=
SELF_URL=
